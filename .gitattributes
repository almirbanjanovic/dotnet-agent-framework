# Shell scripts must use LF line endings — CRLF breaks them on Linux/macOS
# (every shell line that ends with \r is interpreted with a literal CR which
# fails on `bash -n` and crashes mid-script). Forces normalization on commit.
*.sh   text eol=lf
*.bash text eol=lf

# Squad: union merge for append-only team state files
.squad/decisions.md merge=union
.squad/agents/*/history.md merge=union
.squad/log/** merge=union
.squad/orchestration-log/** merge=union
