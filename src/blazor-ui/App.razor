@* CascadingAuthenticationState MUST wrap the MudBlazor providers as well
   as the Router. MudMenu (and other popover-based components like
   MudTooltip / MudAutocomplete / MudSelect) render their child content
   through MudPopoverProvider via a "teleport" pattern; if the popover
   provider is outside the cascade, every <AuthorizeView> inside a popover
   throws "Authorization requires a cascading parameter of type
   Task<AuthenticationState>". Wrapping the entire shell keeps the cascade
   visible to those teleported subtrees, and is the canonical pattern for
   any MudBlazor component that may host AuthorizeView in its content. *@
<CascadingAuthenticationState>
    <MudThemeProvider Theme="@Contoso.BlazorUi.Shared.AppTheme.Theme" />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />

    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    <RedirectToLogin />
                </NotAuthorized>
                <Authorizing>
                    <MudText Typo="Typo.body1">Authorizing&hellip;</MudText>
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <MudText Typo="Typo.body1">Sorry, there's nothing at this address.</MudText>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
