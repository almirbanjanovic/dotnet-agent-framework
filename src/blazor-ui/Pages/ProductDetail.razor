@page "/product/{id}"
@attribute [Authorize]
@inject BffApiClient BffApi
@inject CartService Cart
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>@(_product?.Name ?? "Product") · Contoso Outdoors</PageTitle>

<section class="page-section">
    @if (_isLoading)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_errorMessage</MudAlert>
    }
    else if (_product is { } p)
    {
        <MudBreadcrumbs Items="@_breadcrumbs" Class="mb-4 pa-0" />
        <div class="product-detail">
            <div class="product-detail-image">
                <img src="@BffApi.GetImageUrl(p.ImageFilename)" alt="@p.Name" />
            </div>
            <div class="product-detail-info">
                <span class="product-detail-category">@p.Category</span>
                <h1 class="product-detail-title">@p.Name</h1>
                <div class="product-detail-rating">
                    <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Style="color: #D97706; vertical-align: middle;" />
                    <span>@p.Rating.ToString("0.0") rating</span>
                    @if (p.InStock)
                    {
                        <span class="badge in-stock">In stock</span>
                    }
                    else
                    {
                        <span class="badge out-stock">Out of stock</span>
                    }
                </div>
                <p class="product-detail-description">@p.Description</p>
                <div class="product-detail-price-row">
                    <span class="product-detail-price">@p.Price.ToString("C")</span>
                    <span class="product-detail-sku">SKU: @p.Id</span>
                </div>
                <div class="product-detail-qty-row">
                    <MudNumericField T="int"
                                     @bind-Value="_quantity"
                                     Min="1"
                                     Max="10"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Style="width: 110px;" />
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.AddShoppingCart"
                               Disabled="@(!p.InStock)"
                               OnClick="HandleAddToCart">
                        Add to cart
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.ShoppingCartCheckout"
                               Disabled="@(!p.InStock)"
                               OnClick="HandleBuyNow">
                        Buy now
                    </MudButton>
                </div>
                <ul class="product-detail-features">
                    <li><MudIcon Icon="@Icons.Material.Outlined.LocalShipping" Size="Size.Small" /> Free shipping over $99</li>
                    <li><MudIcon Icon="@Icons.Material.Outlined.AssignmentReturn" Size="Size.Small" /> 30-day returns</li>
                    <li><MudIcon Icon="@Icons.Material.Outlined.Verified" Size="Size.Small" /> 1-year warranty</li>
                </ul>
            </div>
        </div>
    }
</section>

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    private Product? _product;
    private bool _isLoading = true;
    private string? _errorMessage;
    private int _quantity = 1;
    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _quantity = 1;

        try
        {
            _product = await BffApi.GetProductAsync(Id);
            if (_product is null)
            {
                _errorMessage = "Product not found.";
            }
            else
            {
                _breadcrumbs =
                [
                    new BreadcrumbItem("Home", "/"),
                    new BreadcrumbItem(Capitalize(_product.Category), $"/browse?category={Uri.EscapeDataString(_product.Category.ToLowerInvariant())}"),
                    new BreadcrumbItem(_product.Name, null, disabled: true)
                ];
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load product: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void HandleAddToCart()
    {
        if (_product is null) return;
        Cart.Add(_product, _quantity);
        Snackbar.Add($"Added {_quantity} × {_product.Name} to cart", Severity.Success);
    }

    private void HandleBuyNow()
    {
        if (_product is null) return;
        Cart.Add(_product, _quantity);
        Navigation.NavigateTo("/cart");
    }

    private static string Capitalize(string value) =>
        string.IsNullOrEmpty(value) ? value : char.ToUpperInvariant(value[0]) + value[1..];
}
