@page "/orders"
@attribute [Authorize]
@implements IDisposable
@inject BffApiClient BffApiClient
@inject AuthStateProvider AuthStateProvider

<PageTitle>Orders · Contoso Outdoors</PageTitle>

<section class="page-section">
<MudStack Spacing="4">
    <div>
        <MudText Typo="Typo.h4" Style="font-weight: 700;">Order history</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @(AuthStateProvider.SelectedCustomer is { } c
                ? $"Recent orders for {c.Name}."
                : "Sign in to view your order history.")
        </MudText>
    </div>

    @if (_isLoading)
    {
        <MudGrid>
            @for (var i = 0; i < 3; i++)
            {
                <MudItem xs="12" md="6" lg="4">
                    <MudPaper Class="pa-4" Style="height: 220px;">
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="60%" />
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" />
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="100px" Style="margin-top: 1rem;" />
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_errorMessage</MudAlert>
    }
    else if (_orders.Count == 0)
    {
        <MudPaper Class="pa-8" Style="text-align: center;" Elevation="0">
            <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Size="Size.Large" Color="Color.Secondary" />
            <MudText Typo="Typo.h6" Style="margin-top: 0.75rem;">No orders yet</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="margin-bottom: 1rem;">
                You haven't placed any orders. Browse the catalog to get started.
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Storefront"
                       Href="/browse">
                Browse products
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudGrid>
            @foreach (var order in _orders)
            {
                var isExpanded = _expandedOrderIds.Contains(order.Id);
                var subtotal = order.Items?.Sum(i => i.UnitPrice * i.Quantity) ?? 0m;
                <MudItem xs="12" md="6" lg="4">
                    <MudCard Class="card-hover" Style="height: 100%;">
                        <MudCardContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="margin-bottom: 0.75rem;">
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">
                                        Order
                                    </MudText>
                                    <MudText Typo="Typo.h6" Style="line-height: 1.1;">#@order.Id</MudText>
                                </div>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Class="@GetStatusChipClass(order.Status)">
                                    @FormatStatus(order.Status)
                                </MudChip>
                            </MudStack>

                            <MudText Typo="Typo.h5" Style="font-weight: 700; color: #1F5F3F; margin-bottom: 0.5rem;">
                                @order.TotalAmount.ToString("C")
                            </MudText>

                            <MudStack Spacing="1">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Outlined.CalendarToday" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@FormatDate(order.OrderDate)</MudText>
                                </MudStack>
                                @if (!string.IsNullOrWhiteSpace(order.TrackingNumber))
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Outlined.LocalShipping" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@order.TrackingNumber</MudText>
                                    </MudStack>
                                }
                                @if (!string.IsNullOrWhiteSpace(order.EstimatedDelivery))
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Outlined.Schedule" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">ETA @order.EstimatedDelivery</MudText>
                                    </MudStack>
                                }
                            </MudStack>

                            <MudDivider Style="margin: 1rem 0;" />

                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">
                                    Items (@(order.Items?.Count ?? 0))
                                </MudText>
                                @if (order.Items?.Count > 0)
                                {
                                    <MudButton Size="Size.Small"
                                               Variant="Variant.Text"
                                               Color="Color.Primary"
                                               EndIcon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                               OnClick="@(() => ToggleExpanded(order.Id))"
                                               aria-expanded="@(isExpanded ? "true" : "false")"
                                               aria-controls="@($"order-details-{order.Id}")">
                                        @(isExpanded ? "Hide details" : "View details")
                                    </MudButton>
                                }
                            </MudStack>

                            @if (order.Items?.Count > 0)
                            {
                                @if (!isExpanded)
                                {
                                    <MudStack Spacing="0" Style="margin-top: 0.5rem;">
                                        @foreach (var item in order.Items)
                                        {
                                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="padding: 0.3rem 0; border-bottom: 1px dashed rgba(15, 31, 23, 0.06);">
                                                <MudText Typo="Typo.body2">@item.ProductName</MudText>
                                                <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-variant-numeric: tabular-nums;">×@item.Quantity</MudText>
                                            </MudStack>
                                        }
                                    </MudStack>
                                }
                                else
                                {
                                    <MudStack Spacing="2" Style="margin-top: 0.75rem;" id="@($"order-details-{order.Id}")">
                                        @foreach (var item in order.Items)
                                        {
                                            <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center"
                                                      Style="padding: 0.5rem 0; border-bottom: 1px dashed rgba(15, 31, 23, 0.08);">
                                                @if (!string.IsNullOrWhiteSpace(item.ImageFilename))
                                                {
                                                    <img src="@BffApiClient.GetImageUrl(item.ImageFilename)"
                                                         alt="@item.ProductName"
                                                         style="width: 56px; height: 56px; border-radius: 6px; object-fit: cover; flex-shrink: 0; background: rgba(15,31,23,0.04);" />
                                                }
                                                <div style="flex: 1 1 auto; min-width: 0;">
                                                    <MudText Typo="Typo.body2" Style="font-weight: 600; line-height: 1.2; overflow-wrap: anywhere; word-break: break-word;">@item.ProductName</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-variant-numeric: tabular-nums;">
                                                        @item.UnitPrice.ToString("C") × @item.Quantity
                                                    </MudText>
                                                </div>
                                                <MudText Typo="Typo.body2" Style="font-weight: 600; font-variant-numeric: tabular-nums; flex-shrink: 0;">
                                                    @((item.UnitPrice * item.Quantity).ToString("C"))
                                                </MudText>
                                            </MudStack>
                                        }

                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="padding-top: 0.25rem;">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">Items subtotal</MudText>
                                            <MudText Typo="Typo.body2" Style="font-variant-numeric: tabular-nums;">@subtotal.ToString("C")</MudText>
                                        </MudStack>
                                        @if (Math.Abs(order.TotalAmount - subtotal) > 0.005m)
                                        {
                                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">Shipping &amp; tax</MudText>
                                                <MudText Typo="Typo.body2" Style="font-variant-numeric: tabular-nums;">@((order.TotalAmount - subtotal).ToString("C"))</MudText>
                                            </MudStack>
                                        }
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center"
                                                  Style="padding-top: 0.5rem; border-top: 1px solid rgba(15, 31, 23, 0.10);">
                                            <MudText Typo="Typo.body1" Style="font-weight: 700;">Order total</MudText>
                                            <MudText Typo="Typo.body1" Style="font-weight: 700; color: #1F5F3F; font-variant-numeric: tabular-nums;">
                                                @order.TotalAmount.ToString("C")
                                            </MudText>
                                        </MudStack>
                                    </MudStack>
                                }
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top: 0.5rem;">
                                    Item details unavailable.
                                </MudText>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudStack>
</section>

@code {
    private readonly List<Order> _orders = new();
    // Per-card expansion state. Keyed by Order.Id; entries persist across
    // re-renders so a refresh of the order list (e.g. CustomerChanged)
    // doesn't collapse the cards the user just opened. Cleared along with
    // _orders when the signed-in customer becomes null.
    private readonly HashSet<string> _expandedOrderIds = new(StringComparer.Ordinal);
    // Tracks the customer whose orders currently populate _orders, so we
    // can detect a cross-customer switch and reset _expandedOrderIds —
    // necessary because order ids are not guaranteed unique across
    // customers, so the same id from two customers must not share state.
    private string? _lastLoadedCustomerId;
    private bool _isLoading = true;
    private string? _errorMessage;

    // Re-entrancy guard: cancels any in-flight LoadOrdersAsync when a new
    // one starts so we never AddRange the result of a stale fetch on top
    // of a fresh one (which previously produced duplicate cards on first
    // hard refresh because CustomerChanged fired twice in a row).
    private CancellationTokenSource? _loadCts;
    // Lifecycle guard: HandleCustomerChanged is async void; without this
    // flag a queued continuation can call StateHasChanged AFTER the
    // component has been disposed by Blazor's renderer.
    private bool _disposed;

    protected override async Task OnInitializedAsync()
    {
        AuthStateProvider.CustomerChanged += HandleCustomerChanged;
        await LoadOrdersAsync();
    }

    private async Task LoadOrdersAsync()
    {
        if (_disposed)
        {
            return;
        }

        // Cancel any in-flight load and replace the token. Each invocation
        // OWNS its own CTS and disposes it in the finally block — we never
        // dispose a CTS that another in-flight call is still holding.
        var previous = _loadCts;
        var cts = new CancellationTokenSource();
        var token = cts.Token;
        _loadCts = cts;
        previous?.Cancel();

        _isLoading = true;
        _errorMessage = null;

        try
        {
            if (AuthStateProvider.SelectedCustomer is null)
            {
                _orders.Clear();
                _expandedOrderIds.Clear();
                _lastLoadedCustomerId = null;
                return;
            }

            var currentCustomerId = AuthStateProvider.SelectedCustomer.Id;
            var orders = await BffApiClient.GetOrdersAsync(
                currentCustomerId,
                token);

            // Only the *latest* call is allowed to mutate _orders. If a
            // newer load started while we were awaiting the HTTP call,
            // _loadCts no longer points at us — drop our result.
            if (token.IsCancellationRequested || !ReferenceEquals(_loadCts, cts) || _disposed)
            {
                return;
            }

            _orders.Clear();
            _orders.AddRange(orders);

            // On a cross-customer switch, drop ALL expansion state — order
            // ids are scoped per customer and can collide. On a same-customer
            // reload, prune ids that no longer correspond to a visible order.
            if (!string.Equals(_lastLoadedCustomerId, currentCustomerId, StringComparison.Ordinal))
            {
                _expandedOrderIds.Clear();
                _lastLoadedCustomerId = currentCustomerId;
            }
            else if (_expandedOrderIds.Count > 0)
            {
                var liveIds = new HashSet<string>(_orders.Select(o => o.Id), StringComparer.Ordinal);
                _expandedOrderIds.RemoveWhere(id => !liveIds.Contains(id));
            }
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested || _disposed)
        {
            // A newer load (or component teardown) superseded us — silent.
        }
        catch (Exception ex)
        {
            if (ReferenceEquals(_loadCts, cts) && !_disposed)
            {
                _errorMessage = $"Unable to load orders: {ex.Message}";
            }
        }
        finally
        {
            if (ReferenceEquals(_loadCts, cts))
            {
                _isLoading = false;
                _loadCts = null;
            }
            // Dispose the CTS we OWN, not someone else's.
            cts.Dispose();
        }
    }

    private string FormatDate(string? value)
    {
        if (DateTime.TryParse(value, out var parsed))
        {
            return parsed.ToString("d MMM yyyy");
        }

        return value ?? "N/A";
    }

    // Toggles the per-card expansion state. Adds the id if absent,
    // removes it if present. Bound only to the "View details" button —
    // the card itself is intentionally non-clickable so we don't conflict
    // with MudButton's own click handling (which previously caused
    // RZ10010 "OnClick used two or more times" on the MudCard wrapper).
    private void ToggleExpanded(string orderId)
    {
        if (string.IsNullOrWhiteSpace(orderId))
        {
            return;
        }
        if (!_expandedOrderIds.Add(orderId))
        {
            _expandedOrderIds.Remove(orderId);
        }
    }

    private static string GetStatusChipClass(string? status) => status?.ToLowerInvariant() switch
    {
        "delivered"         => "status-chip-success",
        "completed"         => "status-chip-success",
        "shipped"           => "status-chip-info",
        "in transit"        => "status-chip-info",
        "processing"        => "status-chip-warn",
        "pending"           => "status-chip-warn",
        "return-started"    => "status-chip-warn",
        "cancelled"         => "status-chip-muted",
        "returned"          => "status-chip-muted",
        _                   => "status-chip-info"
    };

    // Wire values are kebab-lowercase ('return-started') for API
    // contract stability; the chip text needs to read like a sentence.
    private static string FormatStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status)) return string.Empty;
        var lower = status.ToLowerInvariant();
        return lower switch
        {
            "return-started"   => "Return Started",
            _ => char.ToUpperInvariant(lower[0]) + lower[1..]
        };
    }

    private async void HandleCustomerChanged()
    {
        try
        {
            await InvokeAsync(async () =>
            {
                if (_disposed)
                {
                    return;
                }

                await LoadOrdersAsync();

                if (!_disposed)
                {
                    StateHasChanged();
                }
            });
        }
        catch (ObjectDisposedException)
        {
            // Component was disposed while the renderer callback was queued.
        }
    }

    public void Dispose()
    {
        _disposed = true;
        AuthStateProvider.CustomerChanged -= HandleCustomerChanged;
        // Cancel only — the owning LoadOrdersAsync disposes its own CTS
        // in the finally block so we never dispose a CTS another in-flight
        // operation is still holding.
        _loadCts?.Cancel();
    }
}
