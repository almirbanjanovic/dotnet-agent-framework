@page "/orders"
@attribute [Authorize]
@implements IDisposable
@inject BffApiClient BffApiClient
@inject AuthStateProvider AuthStateProvider

<PageTitle>Orders · Contoso Outdoors</PageTitle>

<section class="page-section">
<MudStack Spacing="4">
    <div>
        <MudText Typo="Typo.h4" Style="font-weight: 700;">Order history</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @(AuthStateProvider.SelectedCustomer is { } c
                ? $"Recent orders for {c.Name}."
                : "Sign in to view your order history.")
        </MudText>
    </div>

    @if (_isLoading)
    {
        <MudGrid>
            @for (var i = 0; i < 3; i++)
            {
                <MudItem xs="12" md="6" lg="4">
                    <MudPaper Class="pa-4" Style="height: 220px;">
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="60%" />
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" />
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="100px" Style="margin-top: 1rem;" />
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_errorMessage</MudAlert>
    }
    else if (_orders.Count == 0)
    {
        <MudPaper Class="pa-8" Style="text-align: center;" Elevation="0">
            <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Size="Size.Large" Color="Color.Secondary" />
            <MudText Typo="Typo.h6" Style="margin-top: 0.75rem;">No orders yet</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="margin-bottom: 1rem;">
                You haven't placed any orders. Browse the catalog to get started.
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Storefront"
                       Href="/browse">
                Browse products
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudGrid>
            @foreach (var order in _orders)
            {
                <MudItem xs="12" md="6" lg="4">
                    <MudCard Class="card-hover" Style="height: 100%;">
                        <MudCardContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="margin-bottom: 0.75rem;">
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">
                                        Order
                                    </MudText>
                                    <MudText Typo="Typo.h6" Style="line-height: 1.1;">#@order.Id</MudText>
                                </div>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Class="@GetStatusChipClass(order.Status)">
                                    @order.Status
                                </MudChip>
                            </MudStack>

                            <MudText Typo="Typo.h5" Style="font-weight: 700; color: #1F5F3F; margin-bottom: 0.5rem;">
                                @order.TotalAmount.ToString("C")
                            </MudText>

                            <MudStack Spacing="1">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Outlined.CalendarToday" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@FormatDate(order.OrderDate)</MudText>
                                </MudStack>
                                @if (!string.IsNullOrWhiteSpace(order.TrackingNumber))
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Outlined.LocalShipping" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@order.TrackingNumber</MudText>
                                    </MudStack>
                                }
                                @if (!string.IsNullOrWhiteSpace(order.EstimatedDelivery))
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Outlined.Schedule" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">ETA @order.EstimatedDelivery</MudText>
                                    </MudStack>
                                }
                            </MudStack>

                            <MudDivider Style="margin: 1rem 0;" />

                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">
                                Items
                            </MudText>
                            @if (order.Items?.Count > 0)
                            {
                                <MudStack Spacing="0" Style="margin-top: 0.5rem;">
                                    @foreach (var item in order.Items)
                                    {
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="padding: 0.3rem 0; border-bottom: 1px dashed rgba(15, 31, 23, 0.06);">
                                            <MudText Typo="Typo.body2">@item.ProductName</MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-variant-numeric: tabular-nums;">×@item.Quantity</MudText>
                                        </MudStack>
                                    }
                                </MudStack>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top: 0.5rem;">
                                    Item details unavailable.
                                </MudText>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudStack>
</section>

@code {
    private readonly List<Order> _orders = new();
    private bool _isLoading = true;
    private string? _errorMessage;

    // Re-entrancy guard: cancels any in-flight LoadOrdersAsync when a new
    // one starts so we never AddRange the result of a stale fetch on top
    // of a fresh one (which previously produced duplicate cards on first
    // hard refresh because CustomerChanged fired twice in a row).
    private CancellationTokenSource? _loadCts;
    // Lifecycle guard: HandleCustomerChanged is async void; without this
    // flag a queued continuation can call StateHasChanged AFTER the
    // component has been disposed by Blazor's renderer.
    private bool _disposed;

    protected override async Task OnInitializedAsync()
    {
        AuthStateProvider.CustomerChanged += HandleCustomerChanged;
        await LoadOrdersAsync();
    }

    private async Task LoadOrdersAsync()
    {
        if (_disposed)
        {
            return;
        }

        // Cancel any in-flight load and replace the token. Each invocation
        // OWNS its own CTS and disposes it in the finally block — we never
        // dispose a CTS that another in-flight call is still holding.
        var previous = _loadCts;
        var cts = new CancellationTokenSource();
        var token = cts.Token;
        _loadCts = cts;
        previous?.Cancel();

        _isLoading = true;
        _errorMessage = null;

        try
        {
            if (AuthStateProvider.SelectedCustomer is null)
            {
                _orders.Clear();
                return;
            }

            var orders = await BffApiClient.GetOrdersAsync(
                AuthStateProvider.SelectedCustomer.Id,
                token);

            // Only the *latest* call is allowed to mutate _orders. If a
            // newer load started while we were awaiting the HTTP call,
            // _loadCts no longer points at us — drop our result.
            if (token.IsCancellationRequested || !ReferenceEquals(_loadCts, cts) || _disposed)
            {
                return;
            }

            _orders.Clear();
            _orders.AddRange(orders);
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested || _disposed)
        {
            // A newer load (or component teardown) superseded us — silent.
        }
        catch (Exception ex)
        {
            if (ReferenceEquals(_loadCts, cts) && !_disposed)
            {
                _errorMessage = $"Unable to load orders: {ex.Message}";
            }
        }
        finally
        {
            if (ReferenceEquals(_loadCts, cts))
            {
                _isLoading = false;
                _loadCts = null;
            }
            // Dispose the CTS we OWN, not someone else's.
            cts.Dispose();
        }
    }

    private string FormatDate(string? value)
    {
        if (DateTime.TryParse(value, out var parsed))
        {
            return parsed.ToString("d MMM yyyy");
        }

        return value ?? "N/A";
    }

    private static string GetStatusChipClass(string? status) => status?.ToLowerInvariant() switch
    {
        "delivered"   => "status-chip-success",
        "completed"   => "status-chip-success",
        "shipped"     => "status-chip-info",
        "in transit"  => "status-chip-info",
        "processing"  => "status-chip-warn",
        "pending"     => "status-chip-warn",
        "cancelled"   => "status-chip-muted",
        "returned"    => "status-chip-muted",
        _             => "status-chip-info"
    };

    private async void HandleCustomerChanged()
    {
        try
        {
            await InvokeAsync(async () =>
            {
                if (_disposed)
                {
                    return;
                }

                await LoadOrdersAsync();

                if (!_disposed)
                {
                    StateHasChanged();
                }
            });
        }
        catch (ObjectDisposedException)
        {
            // Component was disposed while the renderer callback was queued.
        }
    }

    public void Dispose()
    {
        _disposed = true;
        AuthStateProvider.CustomerChanged -= HandleCustomerChanged;
        // Cancel only — the owning LoadOrdersAsync disposes its own CTS
        // in the finally block so we never dispose a CTS another in-flight
        // operation is still holding.
        _loadCts?.Cancel();
    }
}
