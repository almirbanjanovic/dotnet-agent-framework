@inject ChatPanelState ChatPanel
@inject BffApiClient BffApi
@inject AuthStateProvider AuthStateProvider
@inject IJSRuntime JsRuntime
@implements IDisposable

@if (ChatPanel.IsClosed)
{
    <button class="chat-bubble-fab @(_runFabPulse ? "fab-pulse" : "")"
            @onclick="ChatPanel.Toggle"
            aria-label="Open chat assistant">
        <MudIcon Icon="@Icons.Material.Filled.SupportAgent" />
        <span>Need help?</span>
    </button>
}
else if (ChatPanel.IsMinimized)
{
    @* role="button" + tabindex on a <div> avoids the nested-button HTML
       that was previously a <button> wrapping a <MudIconButton>. The
       inner close button is now a real, independently-focusable
       sibling. *@
    <div class="chat-minimized-bar"
         role="button"
         tabindex="0"
         @onclick="ChatPanel.Open"
         @onkeydown="HandleMinimizedKeyDown"
         aria-label="Expand chat assistant">
        <span class="chat-minimized-avatar">AI</span>
        <span class="chat-minimized-label">
            Contoso Assistant
            @if (_messages.Count > 0)
            {
                <span class="chat-minimized-sub">@_messages.Count message@(_messages.Count == 1 ? "" : "s") · click to expand</span>
            }
            else
            {
                <span class="chat-minimized-sub">Click to expand</span>
            }
        </span>
        <span class="chat-minimized-close-wrap"
              @onclick="HandleMinimizedClose"
              @onclick:stopPropagation="true"
              @onkeydown:stopPropagation="true">
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Size="Size.Small"
                           aria-label="Close chat" />
        </span>
    </div>
}
else
{
    <div id="@PanelContainerId" class="chat-panel-floating @(_runPulse ? "panel-pulse" : "")">
        <div class="chat-panel-header">
            <div class="chat-panel-title">
                <span class="chat-panel-avatar">AI</span>
                <div>
                    <div class="chat-panel-name">Contoso Assistant</div>
                    <div class="chat-panel-status">Online · Powered by AI agents</div>
                </div>
            </div>
            <div class="chat-panel-header-actions">
                <MudIconButton Icon="@Icons.Material.Filled.Remove"
                               Size="Size.Small"
                               OnClick="ChatPanel.Minimize"
                               aria-label="Minimize chat" />
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Size="Size.Small"
                               OnClick="ChatPanel.Close"
                               aria-label="Close chat" />
            </div>
        </div>

        <div id="@ScrollContainerId" class="chat-panel-messages">
            @if (_messages.Count == 0 && _streamingText is null)
            {
                <div class="chat-panel-empty">
                    <span class="chat-empty-emoji">👋</span>
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">How can we help today?</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Ask about an order, request a return, or get gear recommendations.
                    </MudText>
                    <div class="chat-panel-suggestions">
                        @foreach (var prompt in _suggestedPrompts)
                        {
                            <button class="chat-panel-suggestion" @onclick="() => UseSuggestion(prompt)">@prompt</button>
                        }
                    </div>
                </div>
            }
            else
            {
                @foreach (var message in _messages)
                {
                    var isUser = string.Equals(message.Role, "user", StringComparison.OrdinalIgnoreCase);
                    <div class="chat-row @(isUser ? "user" : "assistant")">
                        @if (!isUser)
                        {
                            <span class="chat-avatar assistant">AI</span>
                        }
                        <div class="chat-bubble">
                            <div class="markdown-body">@ChatMarkdownRenderer.RenderMarkdown(message.Content, BffApi.BffBaseUrl)</div>
                        </div>
                    </div>
                }
                @if (_isSending)
                {
                    <div class="chat-row assistant">
                        <span class="chat-avatar assistant">AI</span>
                        <div class="chat-bubble">
                            @if (!string.IsNullOrEmpty(_currentStageLabel))
                            {
                                <div class="chat-stage-chip">
                                    <MudIcon Icon="@_currentStageIcon" Size="Size.Small" />
                                    <span>@_currentStageLabel</span>
                                </div>
                            }
                            @foreach (var tool in _currentToolCalls)
                            {
                                <div class="chat-tool-chip">
                                    <MudIcon Icon="@Icons.Material.Filled.Build" Size="Size.Small" />
                                    <span><code>@tool</code></span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(_streamingText))
                            {
                                <div class="markdown-body">@ChatMarkdownRenderer.RenderMarkdown(_streamingText, BffApi.BffBaseUrl)</div>
                            }
                            else if (string.IsNullOrEmpty(_currentStageLabel))
                            {
                                <div class="typing-indicator"><span></span><span></span><span></span></div>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        <div id="@ComposerWrapperId" class="chat-panel-composer">
            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <MudAlert Severity="Severity.Error"
                          Dense="true"
                          ShowCloseIcon="true"
                          CloseIconClicked="@(() => _errorMessage = null)"
                          Class="mb-2">@_errorMessage</MudAlert>
            }
            @if (AuthStateProvider.SelectedCustomer is null)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                    Sign in to chat with our experts.
                </MudAlert>
            }
            <MudTextField @bind-Value="_currentMessage"
                          Variant="Variant.Outlined"
                          Lines="2"
                          Placeholder="Ask about your orders, returns, or gear..."
                          Margin="Margin.Dense"
                          Immediate="true"
                          UserAttributes="@_composerUserAttributes"
                          OnKeyDown="HandleKeyDown" />
            <div class="chat-panel-send-row">
                <span class="chat-panel-hint">
                    <kbd>Enter</kbd> to send · <kbd>Shift+Enter</kbd> for newline
                </span>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           EndIcon="@Icons.Material.Filled.Send"
                           OnClick="SendAsync"
                           Disabled="@IsSendDisabled">
                    @(_isSending ? "Sending…" : "Send")
                </MudButton>
            </div>
        </div>
    </div>
}

@code {
    private const string ScrollContainerId = "chat-panel-scroll";
    private const string PanelContainerId = "chat-panel-container";
    private const string ComposerWrapperId = "chat-panel-composer-wrapper";

    private static readonly string[] _suggestedPrompts =
    [
        "Where is my latest order?",
        "What's your return policy on hiking boots?",
        "Recommend a tent for a 3-person summer trip."
    ];

    private static readonly System.Text.Json.JsonSerializerOptions JsonOptions = new()
    {
        PropertyNameCaseInsensitive = true
    };

    // Client-side DoS caps — symmetric to BFF caps. A compromised or runaway
    // server-side stream cannot OOM the browser by sending unbounded tokens or
    // tool-call events.
    private const int MaxStreamingChars = 256 * 1024;   // 256 KB
    private const int MaxToolCalls = 100;
    private bool _streamCapWarned;

    private readonly List<ChatMessage> _messages = new();
    private string? _conversationId;
    private string _currentMessage = string.Empty;
    private string? _errorMessage;
    private bool _isSending;
    private bool _scrollPending;
    private bool _focusPending;
    private bool _runPulse;
    private bool _runFabPulse;
    private bool _fabDiscoveryChecked;

    // Track previous mode so we only auto-focus on actual transitions
    // INTO Open — repeated Open() calls (which we still want to pulse)
    // must not steal focus from another input the user is in. (B.4/A.5)
    private ChatPanelMode _lastObservedMode = ChatPanelMode.Closed;

    // Cancellation for the delayed "clear pulse class" tasks. Bound to
    // component lifetime so we don't mutate a disposed component or
    // leak orphan tasks. (A.2/B.1)
    private CancellationTokenSource? _pulseClearCts;
    private CancellationTokenSource? _fabPulseClearCts;
    private bool _disposed;

    // Self-reference for JS → .NET callback used by the composer
    // "Enter to send" interop. Created lazily on first attach and
    // disposed in Dispose(). The JS side is idempotent (tags the
    // wrapper element), but we also gate the interop call on this
    // flag so we don't make a JS round-trip on every keystroke render
    // (Immediate="true" causes per-keystroke renders).
    private DotNetObjectReference<ChatBubble>? _selfRef;
    private bool _composerJsHooked;

    // Forwarded as `aria-keyshortcuts` so screen readers announce the
    // non-default Enter-to-send binding on the composer textarea.
    private static readonly Dictionary<string, object?> _composerUserAttributes = new()
    {
        ["aria-keyshortcuts"] = "Enter"
    };

    // ── Streaming-state for the in-flight assistant turn ──
    private string? _streamingText;          // null when not streaming; otherwise the token-by-token assembled text
    private string? _currentStageLabel;      // "Understanding your request…" / "Routed to CRM Agent"
    private string _currentStageIcon = Icons.Material.Filled.Psychology;
    private readonly List<string> _currentToolCalls = new();

    private bool IsSendDisabled =>
        _isSending ||
        string.IsNullOrWhiteSpace(_currentMessage) ||
        AuthStateProvider.SelectedCustomer is null;

    protected override void OnInitialized()
    {
        ChatPanel.Changed += HandleChanged;
        AuthStateProvider.CustomerChanged += HandleCustomerChanged;
    }

    private void UseSuggestion(string prompt)
    {
        _currentMessage = prompt;
        _ = SendAsync();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            // ESC collapses (preserves conversation) — standard popup
            // dismiss affordance. Reviewer A.4/B.7.
            ChatPanel.Minimize();
            return;
        }
        // Note: "Enter to send" is handled by attachChatComposerEnter in
        // index.html, NOT here. MudTextField with Lines>1 renders a
        // <textarea>, and Blazor's `@onkeydown:preventDefault` directive
        // is render-time (static), so we cannot conditionally suppress
        // only the unmodified Enter newline insertion from C#. The JS
        // helper preventDefaults Enter (no modifiers) and invokes
        // OnComposerEnterPressed which calls SendAsync.
    }

    /// <summary>
    /// Invoked by attachChatComposerEnter (index.html) when the user
    /// presses Enter without any modifier in the composer textarea.
    /// Public + [JSInvokable] so the JS interop can reach it.
    /// </summary>
    [JSInvokable]
    public async Task OnComposerEnterPressed()
    {
        if (_disposed) return;
        await InvokeAsync(SendAsync);
    }

    private void HandleMinimizedClose() => ChatPanel.Close();

    private void HandleMinimizedKeyDown(KeyboardEventArgs e)
    {
        // The minimized bar is a div role="button"; surface keyboard
        // activation as a click-equivalent.
        if (e.Key == "Enter" || e.Key == " " || e.Key == "Spacebar")
        {
            ChatPanel.Open();
        }
        else if (e.Key == "Escape")
        {
            ChatPanel.Close();
        }
    }

    private async Task SendAsync()
    {
        if (IsSendDisabled)
        {
            return;
        }

        _errorMessage = null;
        var message = _currentMessage.Trim();
        _currentMessage = string.Empty;

        _messages.Add(new ChatMessage("user", message, DateTimeOffset.UtcNow));
        _scrollPending = true;
        _isSending = true;
        _streamingText = null;
        _currentStageLabel = null;
        _currentToolCalls.Clear();

        try
        {
            await foreach (var ev in BffApi.SendChatStreamAsync(new ChatRequest(message, _conversationId)))
            {
                HandleStreamEvent(ev);
                _scrollPending = true;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to send message: {ex.Message}";
        }
        finally
        {
            // Promote the in-flight streaming text to a final ChatMessage
            // (if any tokens arrived) and reset streaming state. The final
            // bubble carries the same content as what was streaming so the
            // UI doesn't flicker.
            if (!string.IsNullOrEmpty(_streamingText))
            {
                _messages.Add(new ChatMessage("assistant", _streamingText, DateTimeOffset.UtcNow));
            }
            _streamingText = null;
            _currentStageLabel = null;
            _currentToolCalls.Clear();
            _isSending = false;
            _scrollPending = true;
            StateHasChanged();
        }
    }

    private void HandleStreamEvent(ChatStreamEvent ev)
    {
        switch (ev.Event)
        {
            case "conversation":
                {
                    var data = System.Text.Json.JsonSerializer.Deserialize<ConversationStartData>(ev.Data, JsonOptions);
                    if (data is { ConversationId: { Length: > 0 } cid })
                    {
                        _conversationId = cid;
                    }
                    break;
                }
            case "stage":
                {
                    var data = System.Text.Json.JsonSerializer.Deserialize<StageData>(ev.Data, JsonOptions);
                    if (data is null) break;
                    if (string.Equals(data.Stage, "classifying", StringComparison.OrdinalIgnoreCase))
                    {
                        _currentStageLabel = "Understanding your request…";
                        _currentStageIcon = Icons.Material.Filled.Psychology;
                    }
                    else if (string.Equals(data.Stage, "routed", StringComparison.OrdinalIgnoreCase))
                    {
                        var agentLabel = string.Equals(data.Agent, "product", StringComparison.OrdinalIgnoreCase)
                            ? "Product Agent"
                            : "CRM Agent";
                        _currentStageLabel = $"Routed to {agentLabel}";
                        _currentStageIcon = Icons.Material.Filled.SmartToy;
                    }
                    break;
                }
            case "token":
                {
                    var data = System.Text.Json.JsonSerializer.Deserialize<TokenData>(ev.Data, JsonOptions);
                    if (!string.IsNullOrEmpty(data?.Text))
                    {
                        var current = _streamingText ?? string.Empty;
                        var remaining = MaxStreamingChars - current.Length;
                        if (remaining > 0)
                        {
                            _streamingText = data.Text.Length <= remaining
                                ? current + data.Text
                                : current + data.Text.Substring(0, remaining);
                        }
                        else if (!_streamCapWarned)
                        {
                            _streamCapWarned = true;
                            Console.WriteLine($"[ChatBubble] Streaming text cap ({MaxStreamingChars} chars) reached; further tokens dropped.");
                        }
                    }
                    break;
                }
            case "tool":
                {
                    var data = System.Text.Json.JsonSerializer.Deserialize<ToolData>(ev.Data, JsonOptions);
                    if (data is { Name: { Length: > 0 } name } && _currentToolCalls.Count < MaxToolCalls)
                    {
                        _currentToolCalls.Add(name);
                    }
                    break;
                }
            case "done":
                {
                    var data = System.Text.Json.JsonSerializer.Deserialize<DoneData>(ev.Data, JsonOptions);
                    if (data is { ConversationId: { Length: > 0 } cid })
                    {
                        _conversationId = cid;
                    }
                    break;
                }
            case "error":
                {
                    var data = System.Text.Json.JsonSerializer.Deserialize<ErrorData>(ev.Data, JsonOptions);
                    _errorMessage = data?.Message ?? "Unknown error.";
                    break;
                }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_disposed) return;

        if (_scrollPending)
        {
            _scrollPending = false;
            await JsRuntime.InvokeVoidAsync("scrollChatToBottom", ScrollContainerId);
        }

        // Hook the composer textarea's Enter-to-send handler ONCE while
        // the panel is open. We gate on `_composerJsHooked` because
        // `Immediate="true"` causes a re-render per keystroke; without
        // this gate we'd make a JS interop round-trip on every render.
        // The hook is reset to false in HandleChanged when the panel
        // transitions out of Open mode (DOM wrapper is unmounted).
        if (ChatPanel.IsOpen && !_composerJsHooked)
        {
            try
            {
                _selfRef ??= DotNetObjectReference.Create(this);
                await JsRuntime.InvokeVoidAsync(
                    "attachChatComposerEnter", ComposerWrapperId, _selfRef);
                _composerJsHooked = true;
            }
            catch (Microsoft.JSInterop.JSDisconnectedException)
            {
                // Circuit is gone — nothing to attach to.
            }
            catch (TaskCanceledException)
            {
                // Pre-rendering / teardown.
            }
        }

        if (_focusPending && ChatPanel.IsOpen)
        {
            _focusPending = false;
            // Best-effort focus — ignore JSDisconnectedException etc.
            try
            {
                await JsRuntime.InvokeVoidAsync("focusChatInput", ComposerWrapperId);
            }
            catch
            {
                // Pre-rendering, disconnect, or missing element — non-fatal.
            }
        }

        // First-load FAB discovery pulse — fires once per browser via
        // localStorage so returning users aren't pestered.
        if (!_fabDiscoveryChecked && ChatPanel.IsClosed)
        {
            // Set BEFORE the await so a re-render during the JS call
            // can't enter this branch a second time. (B.2)
            _fabDiscoveryChecked = true;
            try
            {
                var firstSeen = await JsRuntime.InvokeAsync<bool>("markChatFabSeen");
                if (firstSeen)
                {
                    _runFabPulse = true;
                    StateHasChanged();
                    await ScheduleClearAsync(2400, isFabPulse: true);
                }
            }
            catch
            {
                // Pre-rendering / no localStorage — silently skip.
            }
        }
    }

    private void HandleCustomerChanged()
    {
        _conversationId = null;
        _messages.Clear();
        _errorMessage = null;
        _currentMessage = string.Empty;
        _streamingText = null;
        _currentStageLabel = null;
        _currentToolCalls.Clear();
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleChanged()
    {
        var prevMode = _lastObservedMode;
        _lastObservedMode = ChatPanel.Mode;

        // When the panel leaves Open mode the composer wrapper is unmounted
        // and our JS keydown listener goes with it. Reset the hook flag so
        // the next OnAfterRenderAsync re-attaches against the fresh DOM.
        if (prevMode == ChatPanelMode.Open && ChatPanel.Mode != ChatPanelMode.Open)
        {
            _composerJsHooked = false;
        }

        // When Open() was called, run the attention animation. Auto-focus
        // ONLY when transitioning from a non-Open mode so repeat Open()
        // calls (e.g. footer link while user is typing in the search box)
        // don't steal focus. (A.5/B.4)
        if (ChatPanel.IsOpen && ChatPanel.PulseRequested)
        {
            ChatPanel.AcknowledgePulse();
            if (prevMode != ChatPanelMode.Open)
            {
                _focusPending = true;
            }
            _ = TriggerAttentionPulseAsync();
        }
        else
        {
            InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// CSS animations don't auto-restart when a class is re-added on
    /// the same element. To guarantee every Open() shows a fresh pulse,
    /// we briefly remove the class, force a render, then re-add it. (A.1)
    /// </summary>
    private async Task TriggerAttentionPulseAsync()
    {
        // Cancel any in-flight clear from a previous pulse.
        _pulseClearCts?.Cancel();
        _pulseClearCts?.Dispose();
        _pulseClearCts = null;

        if (_disposed) return;

        _runPulse = false;
        await InvokeAsync(StateHasChanged);
        // Yield so the DOM actually reflects the class removal before
        // we add it back. Without this, Blazor batches both updates
        // into one render and the animation never restarts.
        await Task.Yield();

        if (_disposed) return;

        _runPulse = true;
        await InvokeAsync(StateHasChanged);
        await ScheduleClearAsync(900, isFabPulse: false);
    }

    private async Task ScheduleClearAsync(int delayMs, bool isFabPulse)
    {
        var cts = new CancellationTokenSource();
        if (isFabPulse)
        {
            _fabPulseClearCts?.Cancel();
            _fabPulseClearCts?.Dispose();
            _fabPulseClearCts = cts;
        }
        else
        {
            _pulseClearCts?.Cancel();
            _pulseClearCts?.Dispose();
            _pulseClearCts = cts;
        }

        try
        {
            await Task.Delay(delayMs, cts.Token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        if (_disposed || cts.IsCancellationRequested)
        {
            return;
        }

        if (isFabPulse)
        {
            _runFabPulse = false;
        }
        else
        {
            _runPulse = false;
        }
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _disposed = true;
        ChatPanel.Changed -= HandleChanged;
        AuthStateProvider.CustomerChanged -= HandleCustomerChanged;
        _pulseClearCts?.Cancel();
        _pulseClearCts?.Dispose();
        _fabPulseClearCts?.Cancel();
        _fabPulseClearCts?.Dispose();
        _selfRef?.Dispose();
        _selfRef = null;
    }
}
