@inherits LayoutComponentBase
@inject AuthStateProvider AuthStateProvider
@inject CartService Cart
@inject ChatPanelState ChatPanel
@inject NavigationManager Navigation
@inject BffApiClient BffApi
@inject AuthenticationStateProvider AuthState
@implements IDisposable

<MudLayout>
    <MudAppBar Color="Color.Inherit" Elevation="0" Dense="true" Fixed="true">
        <a href="/" class="brand-mark" style="text-decoration: none;">
            <div class="brand-logo">
                <MudIcon Icon="@Icons.Material.Filled.Terrain" Size="Size.Small" Style="color: #fff;" />
            </div>
            <div class="brand-text">
                <span class="brand-title">Contoso Outdoors</span>
                <span class="brand-tagline">Premium Gear · Since 1987</span>
            </div>
        </a>

        <div class="category-nav">
            @foreach (var cat in _categories)
            {
                <a href="@($"/browse?category={cat.Slug}")" class="category-link">@cat.Label</a>
            }
        </div>

        <MudSpacer />

        <MudTextField @bind-Value="_searchTerm"
                      Placeholder="Search gear..."
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Class="topbar-search"
                      OnKeyDown="OnSearchKeyDown" />

        <div class="cart-wrap">
            <MudIconButton Icon="@Icons.Material.Outlined.ShoppingCart"
                           Color="Color.Default"
                           OnClick="OpenCart"
                           Class="cart-button"
                           aria-label="Open cart" />
            @if (Cart.ItemCount > 0)
            {
                <span class="cart-badge">@Cart.ItemCount</span>
            }
        </div>

        <MudMenu Icon="@Icons.Material.Filled.AccountCircle"
                 Color="Color.Default"
                 AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight"
                 Dense="true">
            <ChildContent>
                @if (AuthStateProvider.SelectedCustomer is not null)
                {
                    <div class="account-header">
                        <div class="account-avatar">@GetInitials(AuthStateProvider.SelectedCustomer.Name)</div>
                        <div>
                            <div class="account-name">@AuthStateProvider.SelectedCustomer.Name</div>
                            @if (!string.IsNullOrWhiteSpace(AuthStateProvider.Email))
                            {
                                <div class="account-email">@AuthStateProvider.Email</div>
                            }
                        </div>
                    </div>
                    <MudDivider />
                }
                @if (AuthStateProvider.UseDevAuth)
                {
                    @* Dev-auth mode: per-customer items always show because the
                       impersonation dropdown auto-picks a seeded customer. *@
                    <MudMenuItem Icon="@Icons.Material.Outlined.ReceiptLong" Href="/orders">My orders</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Outlined.Person" Href="/profile">My profile</MudMenuItem>
                    <MudDivider />
                    <div class="impersonate-label">Impersonate (dev only)</div>
                    @foreach (var customer in AuthStateProvider.Customers)
                    {
                        <MudMenuItem OnClick="@(() => AuthStateProvider.SetCustomer(customer))">
                            @customer.Name @(AuthStateProvider.SelectedCustomer?.Id == customer.Id ? " ✓" : "")
                        </MudMenuItem>
                    }
                }
                else
                {
                    @* MSAL mode: per-customer items + Sign out only when the
                       framework AuthenticationStateProvider says we're signed
                       in. Anonymous visitors get a single "Sign in" item. *@
                    <AuthorizeView>
                        <Authorized>
                            <MudMenuItem Icon="@Icons.Material.Outlined.ReceiptLong" Href="/orders">My orders</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Outlined.Person" Href="/profile">My profile</MudMenuItem>
                            <MudDivider />
                            <MudMenuItem Icon="@Icons.Material.Outlined.Logout" OnClick="BeginSignOut">Sign out</MudMenuItem>
                        </Authorized>
                        <NotAuthorized>
                            <MudMenuItem Icon="@Icons.Material.Outlined.Login" OnClick="BeginSignIn">Sign in</MudMenuItem>
                        </NotAuthorized>
                    </AuthorizeView>
                }
            </ChildContent>
        </MudMenu>
    </MudAppBar>

    <MudMainContent Class="page-main">
        @Body

        <footer class="site-footer">
            <div class="footer-grid">
                <div>
                    <div class="footer-heading">Contoso Outdoors</div>
                    <p class="footer-text">Premium outdoor gear from people who use it. Climbing in Yosemite to thru-hiking the PCT, we test what we sell.</p>
                </div>
                <div>
                    <div class="footer-heading">Shop</div>
                    @foreach (var cat in _categories)
                    {
                        <a href="@($"/browse?category={cat.Slug}")" class="footer-link">@cat.Label</a>
                    }
                </div>
                <div>
                    <div class="footer-heading">Customer care</div>
                    <a class="footer-link" href="/orders">Order status</a>
                    @* Chat is hidden for anonymous MSAL users (ChatBubble +
                       BFF chat endpoint both require auth); don't surface a
                       link that would open a hidden panel. *@
                    <SignedInOnly>
                        <a class="footer-link" href="#" @onclick="OpenChat" @onclick:preventDefault="true">Chat with an expert</a>
                    </SignedInOnly>
                    <a class="footer-link" href="/profile">Account &amp; loyalty</a>
                </div>
            </div>
            <div class="footer-bottom">© @DateTime.UtcNow.Year Contoso Outdoors · Demo for the .NET Agent Framework lab</div>
        </footer>
    </MudMainContent>

    @if (AuthStateProvider.UseDevAuth)
    {
        <ChatBubble />
    }
    else
    {
        @* MSAL mode: hide ChatBubble for anonymous visitors — the chat
           endpoint requires auth and would 401 on every send. Comes back
           automatically once the user signs in. *@
        <AuthorizeView>
            <Authorized>
                <ChatBubble />
            </Authorized>
        </AuthorizeView>
    }
</MudLayout>

@code {
    private record CategoryEntry(string Slug, string Label);

    private static readonly CategoryEntry[] _categories =
    [
        new("footwear",    "Footwear"),
        new("clothing",    "Clothing"),
        new("backpacks",   "Backpacks"),
        new("tents",       "Tents"),
        new("cooking",     "Cooking"),
        new("accessories", "Accessories")
    ];

    private string _searchTerm = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        Cart.Changed += HandleStateChanged;
        AuthStateProvider.CustomerChanged += HandleStateChanged;

        // Real-Entra mode: ask the BFF "who am I?" once after sign-in so the
        // top-bar greeting and per-customer pages have a customer ID. Dev-auth
        // mode short-circuits inside LoadSignedInCustomerAsync. We also skip
        // the call entirely for anonymous visitors in MSAL mode — /api/v1/me
        // requires a JWT and would otherwise 401 every catalog-only browse.
        if (AuthStateProvider.UseDevAuth)
        {
            await AuthStateProvider.LoadSignedInCustomerAsync(BffApi);
        }
        else
        {
            var state = await AuthState.GetAuthenticationStateAsync();
            if (state.User.Identity?.IsAuthenticated == true)
            {
                await AuthStateProvider.LoadSignedInCustomerAsync(BffApi);
            }
        }
    }

    private void OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter" || string.IsNullOrWhiteSpace(_searchTerm))
        {
            return;
        }

        var term = _searchTerm.Trim();
        Navigation.NavigateTo($"/browse?query={Uri.EscapeDataString(term)}");
    }

    private void OpenCart() => Navigation.NavigateTo("/cart");

    private void OpenChat() => ChatPanel.Open();

    // MSAL's RemoteAuthenticatorView refuses logouts that arrive at
    // /authentication/logout via a plain navigation ("The logout was not
    // initiated from within the page."). NavigateToLogout sets the session
    // state MSAL expects before redirecting, so the logout flow proceeds.
    private void BeginSignOut() => Navigation.NavigateToLogout("authentication/logout");

    // Symmetric to BeginSignOut: NavigateToLogin records the current URL
    // so MSAL can return the user here after they finish authenticating.
    private void BeginSignIn() => Navigation.NavigateToLogin("authentication/login");

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant();
        return string.Concat(parts[0][0], parts[^1][0]).ToUpperInvariant();
    }

    public void Dispose()
    {
        Cart.Changed -= HandleStateChanged;
        AuthStateProvider.CustomerChanged -= HandleStateChanged;
    }
}
